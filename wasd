
#include <Adafruit_LiquidCrystal.h>

Adafruit_LiquidCrystal lcd_1(0);

const int buzzerPin = 8;

int minutes = 25;
int seconds = 0;

void setup()
{
  pinMode(buzzerPin, OUTPUT);

  lcd_1.begin(16, 2);

  lcd_1.setCursor(0,0);
  lcd_1.print("Study Timer");
  delay(2000);
}

void loop()
{
  lcd_1.setCursor(0,0);
  lcd_1.print("Time Left:");

  lcd_1.setCursor(0,1);

  if(minutes < 10)
    lcd_1.print("0");

  lcd_1.print(minutes);
  lcd_1.print(":");

  if(seconds < 10)
    lcd_1.print("0");

  lcd_1.print(seconds);

  delay(1000);

  if(seconds == 0)
  {
    if(minutes == 0)
    {
      lcd_1.clear();

      lcd_1.setCursor(0,0);
      lcd_1.print("Great Job!");

      lcd_1.setCursor(0,1);
      lcd_1.print("Session Done");

      tone(buzzerPin, 1000);
      delay(3000);
      noTone(buzzerPin);

      while(true);
    }

    minutes--;
    seconds = 59;
  }
  else
  {
    seconds--;
  }
}
